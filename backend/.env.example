DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot_platform
# Note: For Docker Compose, change database host from 'localhost' to 'postgres'
# DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@postgres:5432/chatbot_platform

JWT_ACCESS_SECRET=your_access_secret_here_at_least_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_here_at_least_32_characters_long
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here

FRONTEND_URL=http://localhost:5173
PORT=4000
ENVIRONMENT=development
